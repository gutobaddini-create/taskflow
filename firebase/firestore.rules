rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function spacePath(spaceId) {
      return /databases/$(database)/documents/spaces/$(spaceId);
    }

    function isSpaceMember(spaceId) {
      return signedIn()
        && exists(spacePath(spaceId))
        && (
          get(spacePath(spaceId)).data.ownerId == uid()
          || uid() in get(spacePath(spaceId)).data.members
        );
    }

    function isTaskMember(data) {
      return signedIn()
        && (
          data.createdBy == uid()
          || data.assignedTo == uid()
          || uid() in data.participants
        );
    }

    function ownsCreatedData() {
      return signedIn() && request.resource.data.createdBy == uid();
    }

    function ownsUploadedData() {
      return signedIn() && request.resource.data.uploadedBy == uid();
    }

    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && userId == uid();
    }

    match /spaces/{spaceId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == uid()
        && uid() in request.resource.data.members;
      allow read, update, delete: if isSpaceMember(spaceId);
    }

    match /lists/{listId} {
      allow create: if signedIn() && isSpaceMember(request.resource.data.spaceId);
      allow read, update, delete: if isSpaceMember(resource.data.spaceId);
    }

    match /tasks/{taskId} {
      allow create: if ownsCreatedData() && isSpaceMember(request.resource.data.spaceId);
      allow read, update, delete: if isTaskMember(resource.data);
    }

    match /reminders/{reminderId} {
      allow create: if signedIn()
        && request.resource.data.userId == uid()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if signedIn()
        && resource.data.userId == uid()
        && exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /attachments/{attachmentId} {
      allow create: if ownsUploadedData()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /links/{linkId} {
      allow create: if ownsCreatedData()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /customFields/{fieldId} {
      allow create: if ownsCreatedData()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /checklist/{itemId} {
      allow create: if signedIn()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /comments/{commentId} {
      allow create: if signedIn()
        && request.resource.data.authorId == uid()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /activityLog/{activityId} {
      allow create: if signedIn()
        && request.resource.data.userId == uid()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read: if exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
      allow update, delete: if false;
    }

    match /invites/{inviteId} {
      allow create: if ownsCreatedData()
        && exists(/databases/$(database)/documents/tasks/$(request.resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data);
      allow read, update, delete: if signedIn()
        && exists(/databases/$(database)/documents/tasks/$(resource.data.taskId))
        && isTaskMember(get(/databases/$(database)/documents/tasks/$(resource.data.taskId)).data);
    }

    match /pendingOperations/{operationId} {
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow read, update, delete: if signedIn() && resource.data.userId == uid();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
